generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Complex {
  id             Int       @id @default(autoincrement())
  name           String
  address        String
  naverComplexId String?
  customNotes    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  lastScrapedAt  DateTime?
  approvalDate   String?
  areaOptions    String?
  buildings      Int?
  infoScrapedAt  DateTime?
  type           String?
  units          Int?
  year           Int?
  tags           String?
  listings       Listing[]

  @@map("complexes")
}

model Listing {
  id         Int      @id @default(autoincrement())
  complexId  Int
  price      Int
  area       Float
  supplyArea Float?
  floor      String
  direction  String?
  tradetype  String
  memo       String?
  url        String?
  scrapedAt  DateTime @default(now())
  complex    Complex  @relation(fields: [complexId], references: [id], onDelete: Cascade)

  @@map("listings")
}
